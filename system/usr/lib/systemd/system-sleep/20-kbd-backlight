#!/bin/sh
LED=/sys/class/leds/asus::kbd_backlight/brightness
STATE=/var/lib/kbd-backlight.state

case "$1" in
    pre)
        VAL=$(cat "$LED" 2>/dev/null)
        echo "$VAL" > "$STATE"
        logger -t kbd-backlight "pre $2: saved $VAL"
        ;;
    post)
        if [ -r "$STATE" ]; then
            VAL=$(cat "$STATE")
            echo "$VAL" > "$LED"
            logger -t kbd-backlight "post $2: restored $VAL"
        fi
        ;;
esac
