#!/bin/sh
# Boot'ta calisir: onceki boot temiz kapanmadiysa (= muhtemel hard freeze/donma)
# o boot'un kernel + xe/drm loglarini ve sistem bilgisini kaydeder. Boylece
# CS:GO donmasi sonrasi reboot'ta kanit otomatik toplanir (drm/xe #7513 teshisi).
OUT=/var/log/freeze-capture
mkdir -p "$OUT"
# onceki boot temiz mi: shutdown/reboot markeri var mi?
if journalctl -b -1 -o cat -n 60 2>/dev/null | grep -qiE 'Reached target.*(Shutdown|Power-Off|Reboot)|systemd-shutdown|Syncing filesystems'; then
    exit 0   # temiz kapanis, donma degil
fi
TS=$(date +%Y%m%d-%H%M%S 2>/dev/null || echo prev)
F="$OUT/freeze-$TS.txt"
{
    echo "=== UNCLEAN previous boot (probable freeze) ==="
    echo "captured: $(date 2>/dev/null)"; echo "kernel: $(uname -r)"; lspci -nn 2>/dev/null | grep -iE 'VGA|3D'
    echo; echo "=== prev-boot kernel log (last 800) ==="
    journalctl -k -b -1 --no-pager 2>/dev/null | tail -800
    echo; echo "=== prev-boot xe/drm/gpu/hang lines ==="
    journalctl -b -1 --no-pager 2>/dev/null | grep -iE 'xe |drm|gpu|hang|reset|guc|wedged|firmware|BERT|APEI|MCE|lockup' | tail -200
} > "$F" 2>/dev/null
logger -t freeze-capture "unclean prior boot -> saved $F"
# eski kayitlari 10 ile sinirla
ls -1t "$OUT"/freeze-*.txt 2>/dev/null | tail -n +11 | xargs -r rm -f
