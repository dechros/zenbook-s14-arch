#!/bin/bash
# Sync KDE user settings to SDDM greeter

[[ $EUID -ne 0 ]] && exec sudo "$0" "$@"

USER_HOME=$(eval echo ~$(logname 2>/dev/null || echo dechros))
USER_CONFIG="$USER_HOME/.config"

SDDM_THEME_CONF="/usr/share/sddm/themes/breeze/theme.conf"
SDDM_CURSOR_CONF="/etc/sddm.conf.d/theme.conf"
SDDM_KWIN_CONF="/var/lib/sddm/.config/kwinoutputconfig.json"

echo "=== Greeter Sync ==="

# --- Cursor ---
CURSOR=$(grep "^cursorTheme=" "$USER_CONFIG/kcminputrc" 2>/dev/null | cut -d= -f2)
if [[ -n "$CURSOR" ]]; then
    sed -i "s/^CursorTheme=.*/CursorTheme=$CURSOR/" "$SDDM_CURSOR_CONF"
    echo "  Cursor:    $CURSOR"
else
    echo "  Cursor:    unchanged"
fi

# --- Wallpaper ---
RAW=$(grep "^Image=" "$USER_CONFIG/kscreenlockerrc" 2>/dev/null | cut -d= -f2-)
WP_PATH="${RAW#file://}"
    WP_PATH="${WP_PATH%/}"

if [[ -n "$WP_PATH" ]]; then
    if [[ -d "$WP_PATH" ]]; then
        IMG=$(ls "$WP_PATH/contents/images/"*.{png,jpg,webp} 2>/dev/null \
              | awk -F'/' '{print $NF, $0}' \
              | sort -t'x' -k1 -rn \
              | head -1 | cut -d' ' -f2-)
    else
        IMG="$WP_PATH"
    fi

    if [[ -f "$IMG" ]]; then
        sed -i "s|^background=.*|background=$IMG|" "$SDDM_THEME_CONF"
        echo "  Wallpaper: $IMG"
    else
        echo "  Wallpaper: image not found ($WP_PATH)"
    fi
else
    echo "  Wallpaper: unchanged"
fi

# --- Scaling ---
if [[ -f "$USER_CONFIG/kwinoutputconfig.json" ]]; then
    cp "$USER_CONFIG/kwinoutputconfig.json" "$SDDM_KWIN_CONF"
    chown sddm:sddm "$SDDM_KWIN_CONF"
    echo "  Scaling:   kwinoutputconfig.json copied"
else
    echo "  Scaling:   unchanged"
fi

echo "=== Done ==="
