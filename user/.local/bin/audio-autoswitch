#!/bin/bash
# Route EasyEffects output (EQ) to the most-recently-plugged output device
# (headphones / HDMI), falling back to the built-in speaker when nothing else
# is connected. Lunar Lake "sof-soundwire" card. EasyEffects processes all app
# audio and is pinned to one output device; we repoint that pin on plug events
# so the EQ'd audio follows the last-plugged device.
set -u
PREFIX="alsa_output.pci-0000_00_1f.3-platform-sof_sdw.HiFi__"
SPK="Speaker"
EERC="$HOME/.config/easyeffects/db/easyeffectsrc"

# Available external output ports (HDMI*/Headphones), highest priority first.
list_avail() {
    pactl list cards 2>/dev/null | grep -E '\[Out\] (HDMI[0-9]|Headphones):' \
        | grep -v 'not available' | grep -E 'available\)' \
        | sed -E 's/.*\[Out\] ([A-Za-z0-9]+):.*priority: ([0-9]+).*/\2 \1/' \
        | sort -rn | awk '{print $2}'
}

current_port() { grep '^outputDevice=' "$EERC" 2>/dev/null | sed -E "s|.*HiFi__([A-Za-z0-9]+)__sink|\1|"; }

set_output() {
    local port="$1" sink="${PREFIX}${1}__sink"
    [ "$port" = "$(current_port)" ] && return 0
    [ -f "$EERC" ] || return 0
    if grep -q '^outputDevice=' "$EERC"; then
        sed -i "s|^outputDevice=.*|outputDevice=${sink}|" "$EERC"
    else
        printf 'outputDevice=%s\n' "$sink" >> "$EERC"
    fi
    pactl set-default-sink "$sink" 2>/dev/null
    # repoint EasyEffects' pinned output by restarting it (re-reads the config)
    pkill -f 'easyeffects.*service-mode' 2>/dev/null
    sleep 1
    setsid easyeffects --hide-window --service-mode >/dev/null 2>&1 < /dev/null &
    echo "audio-autoswitch -> $port"
}

prev=""
decide() {
    local avail newly target
    avail="$(list_avail)"
    # newly-appeared ports (vs previous scan) = just plugged
    newly="$(comm -23 <(echo "$avail" | sort) <(echo "$prev" | sort) 2>/dev/null | grep -v '^$')"
    if [ -n "$newly" ]; then
        # pick highest-priority among newly plugged
        target="$(echo "$avail" | grep -Fx -f <(echo "$newly") | head -1)"
    elif echo "$avail" | grep -qx "$(current_port)"; then
        target=""   # current still available, keep it
    else
        # current gone -> best available external, else speaker
        target="$(echo "$avail" | head -1)"; [ -z "$target" ] && target="$SPK"
    fi
    prev="$avail"
    [ -n "$target" ] && set_output "$target"
}

decide                      # initial sync
pactl subscribe 2>/dev/null | while read -r line; do
    case "$line" in *"on card"*|*"on server"*) decide ;; esac
done
